--- ab_loot: Periodic scanner that trims NPC inventories so long-lived NPCs never accumulate
--- a corpse-sized hoard. Walks online stalkers via xslice frame-spread; each NPC is rescanned
--- at most once per game-day. Public API (`trim_npc`, `evaluate_item`, `build_state`,
--- `default_policy`) exposes the per-NPC trim and per-item decision so probes, MCM buttons,
--- and other modules can drive trimming externally without going through the scheduler.
---
--- Why scanner, not death-time hook:
---   1. Long-lived NPCs (story NPCs, traders, companions, gulag survivors) keep looting and
---      never die. Death-time only catches NPCs that die. The hoarding population is the
---      population that survives. Hundreds of online stalkers all carrying full hoards drive
---      save bloat, server-object inflation, and steady performance drag.
---   2. Save bloat. Every looted item is a server object persisted in the save. Continuous
---      trim bounds live state; death-time only releases when (and if) the NPC dies.
---   3. Bursty performance. N deaths in a firefight = N trims in the same frame as the corpse
---      spawn. xslice spreads the cost across frames.
---
--- Public API contract:
---   - trim_npc(npc, opts)        apply policy to one NPC; returns counts; opts.dry_run reports without releasing
---   - evaluate_item(npc, it, st) pure per-item decision; returns (action, category)
---   - build_state(npc)           per-NPC snapshot reusable by external callers
---   - default_policy()           returns the canonical policy closure for composition
---
--- Trace + profile parity with AlifePlus: xtrace ids for cycle correlation in logs,
--- xprofiler timing per cycle and per NPC, both null-pattern when DEBUG off (zero luabind).

local ipairs = ipairs
local table_sort, math_min = table.sort, math.min
local os_clock = os.clock
local xlog, xtrace, xprofiler, xslice, xcreature, xtime = xlog, xtrace, xprofiler, xslice, xcreature, xtime
local alife_object, alife_release, level = alife_object, alife_release, level
local IsWeapon, IsOutfit, IsHeadgear, IsItem, IsStalker, IsArtefact = IsWeapon, IsOutfit, IsHeadgear, IsItem, IsStalker, IsArtefact
local RegisterScriptCallback = RegisterScriptCallback

-- Main inventory slots. Engine enumerates KNIFE(1), INV_SLOT_2(2 pistol), INV_SLOT_3(3 rifle),
-- GRENADE(4), BINOCULAR(5), BOLT(6), OUTFIT(7), PDA(8), DETECTOR(9), TORCH(10), ARTEFACT(11),
-- HELMET(12), BACKPACK(13). We walk 1..12 for equipped_ids (item_in_slot is nil-safe per slot
-- per CInventory::ItemFromSlot), and read INV_SLOT_2/3 for ammo_class.
-- Source: xray-monolith/src/xrServerEntities/inventory_space.h:7-43.
local INV_SLOT_2, INV_SLOT_3 = 2, 3
local LAST_MAIN_SLOT = 12

-- Anti-pinata cap on stackable consumables (medkits, food, drugs). Calibrated by goal
-- "outlier detection", not per-section economy. Single knob; per-section nuance can later
-- land in [ab_death_keep] if data justifies it.
local STACKABLE_KEEP_N = 3

-- Per-category cap on non-equipped "big" items (weapon / outfit / headgear / artefact).
-- An NPC keeps equipped + matching ammo + this many extras per category. Tunable via MCM
-- (surplus_per_category). The default 2 leaves a "killed two stalkers, kept their gear"
-- loot pool intact while bounding inventories on long-lived NPCs.
local DEFAULT_SURPLUS_KEEP_N = 2

-- LTX sections in itms_manager.ini_death.
local KEEP_ITEMS_SECTION = "keep_items"
local KEEP_ONE_SECTION = "keep_one"
-- Save-var key written by itms_manager when the player straps a weapon onto an NPC.
local STRAPPED_VAR = "strapped_item"

-- Scheduler.
local SCAN_QUEUE = "ab_loot_scan"
-- Per-cycle batch cap. Picks at most N eligible NPCs per cycle (oldest-scanned first).
local DEFAULT_NPCS_PER_CYCLE = 20
-- xslice step (NPCs trimmed per frame). 1 keeps any single frame cheap.
local DEFAULT_NPCS_PER_FRAME = 1
-- actor_on_update poll interval, wall-seconds. Bounds the cost of "nothing eligible" probes
-- against ~30 fps actor_on_update fire rate. Sourced from os.clock() (no luabind bridge).
local UPDATE_INTERVAL_SEC = 30

local log = xlog.get_logger("AB.LOOT", { outfile = "alifebalance.log" })
-- Mirrors log level >= DEBUG. Updated by _sync_log_level on first update and on_option_change.
-- All hot-path tracing/profiling gates on this so cost is zero when DEBUG is off.
local _dbg = false

-- LTX caches. Lazy: filled on first scan, after itms_manager.ini_death is ready.
local _keep_items_set
local _keep_one_set

-- Per-NPC last-scan timestamp, game-seconds. Persists for the session only; on game load
-- the table is empty and every NPC is eligible. Stale entries (NPC despawned) are harmless
-- (hash by id, ids unique; the engine's id allocator never recycles within a save).
local _last_scan_game_sec = {}

-- Cycle state. Reset per cycle in _start_cycle, used by _visit + _on_cycle_done.
local _cycle_id = 0
local _cycle_tid = 0
local _cycle_visited = 0
local _cycle_released = 0
local _cycle_timer
local _last_update = 0

-- ==================== LTX CACHE ====================

local function _load_keep_items(ini)
    if not ini:section_exist(KEEP_ITEMS_SECTION) then return end
    local line_count = ini:line_count(KEEP_ITEMS_SECTION)
    for i = 0, line_count - 1 do
        local _, id, val = ini:r_line_ex(KEEP_ITEMS_SECTION, i, "", "")
        if val == "true" then _keep_items_set[id] = true end
    end
end

local function _load_keep_one(ini)
    if not ini:section_exist(KEEP_ONE_SECTION) then return end
    local line_count = ini:line_count(KEEP_ONE_SECTION)
    for i = 0, line_count - 1 do
        local _, id = ini:r_line_ex(KEEP_ONE_SECTION, i, "", "")
        if id and id ~= "" then _keep_one_set[id] = true end
    end
end

local function _ensure_caches()
    if _keep_items_set then return end
    local ini = itms_manager and itms_manager.ini_death
    if not ini then return end
    _keep_items_set = {}
    _keep_one_set = {}
    _load_keep_items(ini)
    _load_keep_one(ini)
end

-- ==================== POLICY ====================

local function _is_grenade_item(cls)
    return cls == clsid.wpn_grenade_rgd5_s or cls == clsid.wpn_grenade_f1_s
end

-- Read surplus cap from MCM, default DEFAULT_SURPLUS_KEEP_N when MCM not loaded.
local function _surplus_cap()
    local mcm = ab_mcm and ab_mcm.cfg
    return (mcm and mcm.surplus_per_category) or DEFAULT_SURPLUS_KEEP_N
end

--- Per-NPC snapshot. Reusable by external callers that want to evaluate items against a
--- fixed slot configuration. Pure construction; no engine writes.
--- @safety SAFE - guarded item_in_slot calls; parse_list nil-tolerant
--- @cost O(1) | 5 item_in_slot + up to 2 parse_list (ammo_class) luabind
--- @param npc game_object Online stalker
--- @return table { equipped_ids = {id=true}, equipped_ammo = {sec=true}, section_seen = {}, cat_count = {...}, surplus_cap = N }
function build_state(npc)
    local equipped_ids = {}
    local equipped_ammo = {}

    for slot = 1, LAST_MAIN_SLOT do
        local it = npc:item_in_slot(slot)
        if it then equipped_ids[it:id()] = true end
    end

    local function collect_ammo(wpn)
        if not wpn then return end
        local classes = parse_list(ini_sys, wpn:section(), "ammo_class")
        if not classes then return end
        for _, sec in ipairs(classes) do equipped_ammo[sec] = true end
    end
    collect_ammo(npc:item_in_slot(INV_SLOT_2))
    collect_ammo(npc:item_in_slot(INV_SLOT_3))

    return {
        equipped_ids = equipped_ids,
        equipped_ammo = equipped_ammo,
        section_seen = {},
        cat_count = { weapon = 0, outfit = 0, helmet = 0, artefact = 0 },
        surplus_cap = _surplus_cap(),
    }
end

-- Per-category cap: increment the counter for `cat`, release if cap exceeded.
-- Returns (action, category) tuples consistent with evaluate_item.
local function _apply_cat_cap(state, cat, release_label, keep_label)
    local cap = state.surplus_cap
    local count = state.cat_count[cat] + 1
    state.cat_count[cat] = count
    if count > cap then return "release", release_label end
    return "keep", keep_label
end

--- Per-item decision. Returns (action, category) where action in {"keep","release"}.
--- Mutates state.section_seen and state.cat_count. No engine writes.
---
--- Order matters. First-match wins:
---   1-3  hard keeps (quest / money / curated whitelist)         engine + curated coverage
---   4-5  player intent  (companion-gifted, player-strapped)     mirrors vanilla
---   6    equipped (slots 1/2/3/7/11)                            our guard, not vanilla
---   7    ammo (matching equipped weapon kept, else released)    ours
---   8    [keep_one] grenades                                    vanilla owns the 1-cap
---   9-12 per-category surplus cap (weapon/outfit/helmet/aft)    ours, MCM-tunable
---   13   stackable cap N=3                                      ours, consumable bound
---
--- Vanilla [keep_items] is NOT moot in the presence of the quest gate. About half its
--- entries have kind=i_quest (quest gate catches), the other half are quest-given uniques
--- whose kind is the normal weapon/device class (gauss has kind=w_sniper, scientific
--- detector inherits from detector_elite). The whitelist patches those gaps.
---
--- @safety SAFE - nil-guarded section/cls; state table required
--- @cost O(1) | hash lookups + a few IsItem/IsWeapon/IsOutfit/IsHeadgear/IsArtefact bridges
--- @param npc game_object Owner of the item
--- @param item game_object Item to evaluate
--- @param state table From build_state(npc)
--- @return string,string action ("keep"|"release"), category
function evaluate_item(npc, item, state)
    local section = item:section()
    local item_id = item:id()
    local npc_id = npc:id()

    -- Hard keeps: engine quest flag, money, and curated unique-quest whitelist.
    if IsItem("quest", section) then return "keep", "quest" end
    if IsItem("money", section) then return "keep", "money" end
    if _keep_items_set and _keep_items_set[section] then return "keep", "whitelist" end

    -- Player intent: companion-gifted gear and player-strapped weapons.
    if axr_companions and axr_companions.is_assigned_item
       and axr_companions.is_assigned_item(npc_id, item_id) then
        return "keep", "companion"
    end
    -- se_load_var ignores the `name` arg (only used for debug printf in _g.script:2647); the
    -- lookup is by id + varname only. Literal placeholder satisfies the pstor-nil-key validator.
    if se_load_var(item_id, "ab_loot", STRAPPED_VAR) then
        return "keep", "strapped"
    end

    -- Equipped: never released regardless of category.
    if state.equipped_ids[item_id] then return "keep", "equipped" end

    -- Ammo: matching equipped weapon's ammo_class kept (unbounded); rest released.
    if IsItem("ammo", section) then
        if state.equipped_ammo[section] then return "keep", "ammo_matched" end
        return "release", "ammo"
    end

    -- Vanilla [keep_one] grenades; vanilla owns the per-section 1-cap.
    if _keep_one_set and _keep_one_set[section] then return "keep", "keep_one" end

    -- Per-category surplus cap. Counted only when reached this point (equipped + ammo
    -- already short-circuited). Equipped items do NOT count toward the cap.
    local cls = item:clsid()
    if IsWeapon(item, cls) and not _is_grenade_item(cls) then
        return _apply_cat_cap(state, "weapon", "weapon", "weapon_surplus")
    end
    if IsOutfit(nil, cls) then
        return _apply_cat_cap(state, "outfit", "outfit", "outfit_surplus")
    end
    if IsHeadgear(nil, cls) then
        return _apply_cat_cap(state, "helmet", "helmet", "helmet_surplus")
    end
    if IsArtefact(item, cls) then
        return _apply_cat_cap(state, "artefact", "artefact", "artefact_surplus")
    end

    -- Stackable cap for everything else (consumables: medkits, food, drugs, bandages,
    -- repair kits, devices NPCs may hoard multiples of the same section).
    local seen = (state.section_seen[section] or 0) + 1
    state.section_seen[section] = seen
    if seen > STACKABLE_KEEP_N then
        return "release", "stackable"
    end
    return "keep", "default"
end

--- Returns the canonical policy as a callable for composition. External callers can wrap
--- the default to add their own rules (e.g. preserve a specific section).
--- @return function evaluate_item
function default_policy()
    return evaluate_item
end

-- ==================== PER-NPC TRIM (PUBLIC) ====================

-- Apply a collected release list, update counters, emit per-release log lines. Kept as a
-- helper so trim_npc's body stays at nesting depth 2 (code-standards.md:125). Caller passes
-- do_release=false to dry-run (counters update, no engine release).
local function _apply_releases(releases, result, do_release, npc_id)
    for _, rel in ipairs(releases) do
        if do_release then alife_release(rel.se) end
        result.released = result.released + 1
        local key = result.released_by_category[rel.category] ~= nil and rel.category or "stackable"
        result.released_by_category[key] = result.released_by_category[key] + 1
        if _dbg then log.debug("[RELEASE] npc=%d section=%s category=%s", npc_id, rel.section, rel.category) end
    end
end

--- Apply policy to one NPC. Public; the scheduler calls this for each NPC in its batch but
--- callers (probes, MCM buttons, other modules) may call it directly. The cooldown table is
--- the scheduler's concern: trim_npc never touches it, so repeated calls all trim.
--- @safety SAFE - returns nil on nil npc; iterate_inventory tolerates nil item entries
--- @cost O(items) | 1 build_state (5 item_in_slot + parse_list) + iterate_inventory + 0-N alife_release per release
--- @param npc game_object Online stalker
--- @param opts table|nil { dry_run = false, policy = nil }
--- @return table|nil { items, released, released_by_category = {weapon, outfit, ammo, stackable}, dt_ms }
function trim_npc(npc, opts)
    if not npc then return nil end
    opts = opts or {}
    local dry_run = opts.dry_run == true
    local policy = opts.policy or evaluate_item

    _ensure_caches()

    local trace = xtrace.new_if(_dbg)
    local seg = trace:push("trim_npc")
    local timer = xprofiler.new_if(_dbg):start()

    local state = build_state(npc)
    local result = {
        items = 0,
        released = 0,
        released_by_category = { weapon = 0, outfit = 0, helmet = 0, ammo = 0, artefact = 0, stackable = 0 },
        dt_ms = 0,
    }
    local npc_id = npc:id()

    -- Collect-then-release: mutation during iterate_inventory is unsafe (engine event queue
    -- can interleave; deepseek-inventory-iteration-mutation rule enforces this).
    local releases = {}
    npc:iterate_inventory(function(_, item)
        if not item then return end
        result.items = result.items + 1
        local action, category = policy(npc, item, state)
        if action ~= "release" then return end
        local se_item = alife_object(item:id())
        if not se_item then return end
        releases[#releases + 1] = { se = se_item, category = category, section = item:section() }
    end, npc)

    _apply_releases(releases, result, not dry_run, npc_id)

    timer:stop()
    result.dt_ms = timer:get_ms()

    if _dbg then
        local rel_cnt = result.released_by_category
        log.debug("[VISIT] npc=%d items=%d released=%d (W=%d O=%d H=%d Am=%d Af=%d Stk=%d) dt=%.3fms",
            npc_id, result.items, result.released,
            rel_cnt.weapon, rel_cnt.outfit, rel_cnt.helmet,
            rel_cnt.ammo, rel_cnt.artefact, rel_cnt.stackable, result.dt_ms)
    end
    trace:pop(seg)

    return result
end

-- ==================== SCHEDULER ====================

local function _cfg()
    return ab_mcm and ab_mcm.cfg or nil
end

local function _enabled()
    local mcm = _cfg()
    return mcm and mcm.enabled_loot ~= false
end

local function _cfg_step()
    local mcm = _cfg()
    return (mcm and mcm.npcs_per_frame) or DEFAULT_NPCS_PER_FRAME
end

local function _cfg_batch()
    local mcm = _cfg()
    return (mcm and mcm.npcs_per_cycle) or DEFAULT_NPCS_PER_CYCLE
end

local function _cfg_cooldown_sec()
    local mcm = _cfg()
    local hours = mcm and mcm.scan_cooldown_h or 24
    return hours * 3600
end

-- Single-NPC eligibility predicate. Returns (id, last_scan_time) on accept; (nil, reason)
-- on reject. Flat returns keep _pick_eligible at depth 2 and let the caller bucket rejection
-- counts by reason. Traders are skipped via utils_obj.is_trader (community=trader, clsid
-- script_trader/trader, section name contains "trader", or storage logic has a `trade` line).
-- Trader stock IS the trader; trimming it breaks the economy.
local function _is_eligible(obj, actor_id, now, cooldown_sec)
    local id = obj:id()
    if id == actor_id then return nil, "actor" end
    if not IsStalker(obj) then return nil, "nonstalker" end
    if not obj:alive() then return nil, "dead" end
    if utils_obj and utils_obj.is_trader and utils_obj.is_trader(obj) then return nil, "trader" end
    local last = _last_scan_game_sec[id] or 0
    if now - last < cooldown_sec then return nil, "cooldown" end
    return id, last
end

-- Walk online stalkers, pick the batch_cap NPCs whose last_scan is older than cooldown,
-- oldest-scanned first. Skips actor, dead, non-stalkers, traders, and NPCs still inside the
-- cooldown window. Times itself and reports rejection counts by reason so the [PICK] log
-- can surface the eligible-set composition.
-- @cost O(N online + K log K) where K = eligible count; sort dominated by table.sort
local function _pick_eligible(batch_cap, cooldown_sec)
    local timer = xprofiler.new_if(_dbg):start()
    local stats = {
        total = 0, eligible = 0, dt_ms = 0,
        actor = 0, nonstalker = 0, dead = 0, trader = 0, cooldown = 0,
    }
    if not (db and db.actor) then
        timer:stop(); stats.dt_ms = timer:get_ms()
        return {}, stats
    end

    local actor_id = db.actor:id()
    local now = xtime.game_sec()
    local eligible = {}

    for obj in xcreature.online_iter() do
        stats.total = stats.total + 1
        local id, last_or_reason = _is_eligible(obj, actor_id, now, cooldown_sec)
        if id then
            eligible[#eligible + 1] = { id = id, last = last_or_reason }
        else
            stats[last_or_reason] = stats[last_or_reason] + 1
        end
    end

    table_sort(eligible, function(a, b) return a.last < b.last end)

    local take = math_min(#eligible, batch_cap)
    local picks = {}
    for i = 1, take do picks[i] = eligible[i].id end

    stats.eligible = #eligible
    timer:stop()
    stats.dt_ms = timer:get_ms()
    return picks, stats
end

local function _on_cycle_done()
    if _cycle_timer then _cycle_timer:stop() end
    if _dbg then
        local ms = _cycle_timer and _cycle_timer:get_ms() or 0
        log.debug("[SCAN] cycle=%d tid=%d visited=%d released=%d dt=%.2fms",
            _cycle_id, _cycle_tid, _cycle_visited, _cycle_released, ms)
    end
    _cycle_timer = nil
end

local function _visit(npc_id)
    local npc = level.object_by_id(npc_id)
    if not npc then
        if _dbg then log.debug("[SKIP] reason=offline npc=%d", npc_id) end
        return true
    end
    if not npc:alive() then
        if _dbg then log.debug("[SKIP] reason=dead npc=%d", npc_id) end
        return true
    end

    local result = trim_npc(npc)
    _last_scan_game_sec[npc_id] = xtime.game_sec()
    _cycle_visited = _cycle_visited + 1
    if result then _cycle_released = _cycle_released + result.released end
    return true
end

local function _start_cycle()
    if not _enabled() then return end
    if xslice.is_active(SCAN_QUEUE) then return end

    local picks, ps = _pick_eligible(_cfg_batch(), _cfg_cooldown_sec())

    if _dbg then
        log.debug("[PICK] online=%d eligible=%d picked=%d (skip: actor=%d nonstalker=%d dead=%d trader=%d cooldown=%d) dt=%.2fms",
            ps.total, ps.eligible, #picks,
            ps.actor, ps.nonstalker, ps.dead, ps.trader, ps.cooldown, ps.dt_ms)
    end

    if #picks == 0 then return end

    _cycle_id = _cycle_id + 1
    _cycle_visited = 0
    _cycle_released = 0
    _cycle_tid = xtrace.new_if(_dbg).id
    _cycle_timer = xprofiler.new_if(_dbg):start()

    if _dbg then
        log.debug("[SCAN] cycle=%d tid=%d open batch=%d step=%d cooldown=%dh",
            _cycle_id, _cycle_tid, #picks, _cfg_step(), _cfg_cooldown_sec() / 3600)
    end

    xslice.start(SCAN_QUEUE, picks, {
        step = _cfg_step(),
        func = _visit,
        on_done = _on_cycle_done,
    })
end

local function actor_on_update()
    if not _enabled() then return end
    if xslice.is_active(SCAN_QUEUE) then return end
    local now = os_clock()
    if now - _last_update < UPDATE_INTERVAL_SEC then return end
    _last_update = now
    _start_cycle()
end

-- ==================== INSTALL ====================

local function _sync_log_level()
    local mcm = _cfg()
    if not mcm then return end
    log.set_level(mcm.log_level or "WARN")
    _dbg = log.get_level() >= 5
end

-- Prune the per-NPC cooldown row when an NPC despawns. The table is hash-by-id and ids
-- never recycle within a save, so the entry would otherwise leak. Cheap: one hash erase.
local function npc_on_net_destroy(npc)
    if not npc then return end
    _last_scan_game_sec[npc:id()] = nil
end

function on_game_start()
    _last_update = 0
    _last_scan_game_sec = {}
    log.info("[INSTALL] ab_loot scanner armed (stackable_n=%d batch=%d)",
        STACKABLE_KEEP_N, DEFAULT_NPCS_PER_CYCLE)
    RegisterScriptCallback("actor_on_first_update", _sync_log_level)
    RegisterScriptCallback("on_option_change", _sync_log_level)
    RegisterScriptCallback("actor_on_update", actor_on_update)
    RegisterScriptCallback("npc_on_net_destroy", npc_on_net_destroy)
end
