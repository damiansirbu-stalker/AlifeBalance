--- ab_test_flows: flow-integration tests for AlifeBalance. Each test is a self-
--- contained @export console function named `ab_test_<flow>()`. Convention is
--- mod_test_<flow>; the file aggregates flow tests within a mod.
---
--- Output: per-session log file `appdata/logs/test_alifebalance_<YYYY-MM-DD>_<HH-MM-SS>.log`.
--- xlog with explicit flush per line so the file appears immediately; no buffer wait.
--- PASS / FAIL also surfaces as a yellow news_manager tip with full summary.
---
--- Run from the X-Ray debug console (requires `-dbg` or `-dbgdev` in launch args):
---   run_string ab_test_flows.ab_test_inventory_sanitization()
---
--- Each test owns its own setup / inject / action / assert / teardown cycle so
--- repeated runs are idempotent. Test functions never touch the scheduler -
--- they call the SUT (e.g. trim_npc) directly so timing is deterministic.

local pairs, ipairs, type, tostring = pairs, ipairs, type, tostring
local string_format = string.format
local math_max, math_min, math_huge = math.max, math.min, math.huge
local xlog, xinventory, xcreature = xlog, xinventory, xcreature
local alife_object, alife_release_id = alife_object, alife_release_id
local IsStalker, level = IsStalker, level

local MOD = "alifebalance"

-- ==================== LOGGING ====================

-- session-cached logger; one file per game session, appears immediately on disk
local _log
local function _get_log()
    if _log then return _log end
    local ts = os.date("%Y-%m-%d_%H-%M-%S")
    _log = xlog.get_logger("TEST", { outfile = string_format("test_%s_%s.log", MOD, ts) })
    return _log
end

-- xlog facade methods are plain functions (not OO methods). Call with `.`, not `:`.
local function _log_info(msg, ...)
    _get_log().info(msg, ...)
    xlog.flush_all()
end

local function _tip(msg, ms)
    if db and db.actor then news_manager.send_tip(db.actor, msg, nil, nil, ms or 25000) end
end

-- ==================== HARNESS HELPERS ====================

-- Pick the nearest online stalker that passes xcreature.is_unscriptable.
local function _pick_npc()
    local actor = db.actor
    if not actor then return nil end
    local actor_pos = actor:position()
    local actor_id = actor:id()
    local best, best_dist = nil, math_huge
    for obj in xcreature.online_iter() do
        if obj:id() ~= actor_id and IsStalker(obj) and obj:alive()
            and not xcreature.is_unscriptable(obj) then
            local dist = obj:position():distance_to_sqr(actor_pos)
            if dist < best_dist then best, best_dist = obj, dist end
        end
    end
    return best
end

-- alife_create_item returns:
--   single cse userdata for non-ammo
--   array of cse for ammo when t.ammo exceeds box_size (engine splits)
local function _extract_ids(se)
    if not se then return {} end
    local se_type = type(se)
    if se_type == "userdata" then
        local id = (type(se.id) == "function" and se:id()) or se.id
        return id and { id } or {}
    end
    if se_type == "table" then
        if se.id then return { se.id } end
        local ids = {}
        for i = 1, #se do
            local cse = se[i]
            local id = cse and ((type(cse.id) == "function" and cse:id()) or cse.id)
            if id then ids[#ids + 1] = id end
        end
        return ids
    end
    return {}
end

local function _inject(npc, sec, count, ammo)
    local all_ids = {}
    for i = 1, count do
        local se = xinventory.create_item(sec, npc:id(), ammo and { ammo = ammo } or nil)
        local ids = _extract_ids(se)
        if #ids == 0 then
            _log_info("[INJECT WARN] %s #%d create returned type=%s (no ids)", sec, i, type(se))
        end
        for _, id in ipairs(ids) do all_ids[#all_ids + 1] = id end
    end
    return all_ids
end

local function _cleanup(ids)
    local released = 0
    for _, id in ipairs(ids or {}) do
        if alife_object(id) then alife_release_id(id); released = released + 1 end
    end
    return released
end

local function _find_mismatched_ammo(opts)
    local candidates = {
        "ammo_9x18_fmj", "ammo_pkm_100", "ammo_gauss",
        "ammo_5.45x39_fmj", "ammo_12x76_dart", "ammo_5.7x28_ss190",
        "ammo_9x39_pab9", "ammo_7.62x54_7h1",
    }
    for _, sec in ipairs(candidates) do
        if ini_sys:section_exist(sec)
            and xinventory.resolve_ammo_category(sec, opts) == "ammo_not_equipped" then
            return sec
        end
    end
    return nil
end

-- ==================== TESTS ====================

--- Inventory sanitization: ab_inventory_balance.trim_npc end-to-end.
--- Inject 20 medkits + 1 stack of mismatched ammo (200 rounds) into the
--- nearest test-eligible NPC, run trim_npc, assert the per-category release
--- counts match the ceilings in ab_inventory_policy.ltx.
--- @export console
function ab_test_inventory_sanitization()
    local TEST = "inventory_sanitization"
    _log_info("[BEGIN] %s", TEST)

    local npc = _pick_npc()
    if not npc then
        _log_info("[FAIL] %s: no eligible NPC near actor", TEST)
        _tip("[FAIL] " .. TEST .. ": no eligible NPC")
        return
    end
    local npc_id = npc:id()
    local npc_name = npc:name() or "?"
    _log_info("[SETUP] npc=%d name=%s", npc_id, npc_name)

    local opts = xinventory.get_category_opts(npc)
    local before = xinventory.classify(npc, opts)
    _log_info("[SNAPSHOT before] medkit=%d ammo_not_equipped=%d",
        before.medkit or 0, before.ammo_not_equipped or 0)

    local mismatched = _find_mismatched_ammo(opts)
    if not mismatched then
        _log_info("[FAIL] %s: no mismatched ammo section found", TEST)
        _tip("[FAIL] " .. TEST .. ": no mismatched ammo section")
        return
    end

    local INJECT_MEDKIT = 20
    local INJECT_AMMO = 200
    local medkit_ids = _inject(npc, "medkit", INJECT_MEDKIT)
    local ammo_ids = _inject(npc, mismatched, 1, INJECT_AMMO)
    _log_info("[INJECT] medkit ids=%d (requested %d), %s ids=%d (requested 1 stack of %d rounds)",
        #medkit_ids, INJECT_MEDKIT, mismatched, #ammo_ids, INJECT_AMMO)

    -- alife->CInventory sync takes one frame. Defer the assertion by 1 second.
    -- NOTE: never cache CreateTimeEvent globals as locals - demonized_time_events
    -- replaces them at runtime (doc/library/xray/internals/globals.md:208-219).
    CreateTimeEvent(0, "ab_test_inv_sanit_phase2", 1, function()
        local npc2 = level.object_by_id(npc_id)
        if not npc2 then
            _log_info("[FAIL] %s: npc went offline before phase 2", TEST)
            _tip("[FAIL] " .. TEST .. ": npc offline")
            _cleanup(medkit_ids); _cleanup(ammo_ids)
            return true
        end

        local opts2 = xinventory.get_category_opts(npc2)
        local mid = xinventory.classify(npc2, opts2)
        local mid_medkit = mid.medkit or 0
        local mid_ammo = mid.ammo_not_equipped or 0
        _log_info("[SNAPSHOT mid] medkit=%d ammo_not_equipped=%d", mid_medkit, mid_ammo)

        local result = ab_inventory_balance.trim_npc(npc2)
        _log_info("[ACTION] trim_npc released=%d dt=%.2fms", result.released, result.dt_ms)
        for cat, count in pairs(result.released_by_category) do
            _log_info("[ACTION]   released %s = %d", cat, count)
        end

        local MEDKIT_MAX = 3
        local expected_medkit_released = math_max(mid_medkit - MEDKIT_MAX, 0)
        local actual_medkit_released = (result.released_by_category.medkit) or 0
        local actual_ammo_released = (result.released_by_category.ammo_not_equipped) or 0
        local expected_medkit_after = math_min(mid_medkit, MEDKIT_MAX)

        local ok_medkit = (actual_medkit_released == expected_medkit_released)
        local ok_ammo = (actual_ammo_released >= 1) and (mid_ammo > 0)

        local summary = string_format(
            "npc=%d %s | medkit %d->%d (released %d, cap %d) | ammo_neq %d (released %d stacks) | dt=%.2fms",
            npc_id, npc_name,
            mid_medkit, expected_medkit_after, actual_medkit_released, MEDKIT_MAX,
            mid_ammo, actual_ammo_released, result.dt_ms)

        _log_info("[SUMMARY] %s", summary)

        if ok_medkit and ok_ammo then
            _log_info("[PASS] %s | %s", TEST, summary)
            _tip(string_format("[PASS] %s\n%s", TEST, summary), 30000)
        else
            local reason = string_format(
                "medkit released=%d expected=%d ok=%s | ammo released=%d expected>=1 (mid=%d) ok=%s",
                actual_medkit_released, expected_medkit_released, tostring(ok_medkit),
                actual_ammo_released, mid_ammo, tostring(ok_ammo))
            _log_info("[FAIL] %s | %s | %s", TEST, summary, reason)
            _tip(string_format("[FAIL] %s\n%s\n%s", TEST, summary, reason), 30000)
        end

        local m_cleaned = _cleanup(medkit_ids)
        local a_cleaned = _cleanup(ammo_ids)
        _log_info("[TEARDOWN] released %d/%d medkit ids, %d/%d ammo ids (others already gone via trim)",
            m_cleaned, #medkit_ids, a_cleaned, #ammo_ids)
        return true
    end)
end
