--- ab_test: test harness for AlifeBalance. Two test surfaces in one module.
---
--- 1. Kill loop: fires one fake NPC death every KILL_INTERVAL wall seconds, alternating
---    on-actor-level vs off-actor-level pools (strict 1:1). Same vermin filter as
---    ab_smart_balance so the test exercises the same code path. Logs to alifebalance.log.
---
--- 2. Flow-integration tests: self-contained @export console functions named
---    ab_test_<flow>(). Each owns its own setup / inject / action / assert / teardown so
---    repeated runs are idempotent. Tests call the SUT (e.g. trim_npc) directly so timing
---    is deterministic. Output goes to a per-session log file
---    appdata/logs/test_alifebalance_<YYYY-MM-DD>_<HH-MM-SS>.log; xlog with explicit flush
---    per line so the file appears immediately. PASS / FAIL also surfaces as a yellow
---    news_manager tip.
---
--- Run from the X-Ray debug console (requires `-dbg` or `-dbgdev` in launch args):
---   Kill loop:
---     run_string db.actor:give_info_portion("ab_test_authorized")  -- one-time per save
---     run_string ab_test.start()
---     run_string ab_test.stop()
---     run_string ab_test.toggle()
---   Flow tests:
---     run_string ab_test.ab_test_inventory_sanitization()
---
--- The authorize info portion is a deliberate two-step gate on the kill loop; start()
--- refuses without it. This prevents accidental console runs (typos, copy-pasted commands)
--- from killing real NPCs across the actor's whole world. Revoke with disable_info_portion
--- when done.

local pairs, ipairs, type, tostring, math_random = pairs, ipairs, type, tostring, math.random
local string_format = string.format
local math_max, math_min, math_huge = math.max, math.min, math.huge
local xlog, xsquad, xlevel, xcreature, xinventory = xlog, xsquad, xlevel, xcreature, xinventory
local alife_object, alife_release_id = alife_object, alife_release_id
local IsStalker, level = IsStalker, level
-- NOTE: never cache CreateTimeEvent/ResetTimeEvent/RemoveTimeEvent as locals
-- (doc/library/xray/internals/globals.md:208-219). demonized_time_events.script
-- replaces the globals at load time; cached locals point at a dead queue.

local log = xlog.get_logger("AB.TEST", { outfile = "alifebalance.log" })

local TIMER_EV       = "ab_test"
local TIMER_TICK     = "kill"
local KILL_INTERVAL  = 3
local AUTHORIZE_INFO = "ab_test_authorized"
local MOD            = "alifebalance"

-- ==================== KILL LOOP ====================

-- _tick_count is monotonic and used for strict on/off-level alternation in _pick_pool.
local _running    = false
local _kills      = 0
local _skips      = 0
local _tick_count = 0

-- True if this squad's members are valid kill targets. SIMBOARD assigns a
-- squad to at most one smart at a time (sim_board.script:242-258), so no
-- cross-smart dedup is needed in the caller.
local function _is_valid_squad(squad)
    if not squad then return false end
    if squad:npc_count() == 0 then return false end
    if ab_smart_balance.is_vermin_squad(squad) then return false end
    return true
end

local function _collect_squad_members(squad, out)
    if squad:npc_count() == 0 then return end
    for member in squad:squad_members() do
        out[#out + 1] = member.id
    end
end

local function _collect_smart_squads(rec, out)
    for squad_id in pairs(rec.squads or {}) do
        local squad = alife_object(squad_id)
        if _is_valid_squad(squad) then
            _collect_squad_members(squad, out)
        end
    end
end

-- Walk every smart in SIMBOARD, partition assigned squads by level vs the
-- actor's level. Returns two arrays: on-level npc_ids, off-level npc_ids.
local function _collect_candidates_split(actor_level_id)
    local on_level, off_level = {}, {}
    local board = SIMBOARD
    if not board or not board.smarts then return on_level, off_level end
    for _, rec in pairs(board.smarts) do
        local smart = rec.smrt
        local smart_level = smart and xlevel.get_level_id(smart)
        if smart_level then
            local target = (smart_level == actor_level_id) and on_level or off_level
            _collect_smart_squads(rec, target)
        end
    end
    return on_level, off_level
end

-- Collect display fields for the PDA tip and the [TEST] kill log. Reads creature
-- name (xcreature.get_name), faction (squad.player_id), assigned smart name
-- (xlevel.get_smart_display_name), and level name (xlevel.get_level_name).
-- All lookups are nil-guarded; any missing field falls back to "?".
local function _kill_details(npc_id)
    local npc_se = alife_object(npc_id)
    if not npc_se then return nil end
    local squad        = xsquad.get_squad_by_member(npc_id)
    local creature     = xcreature.get_name(npc_se) or "?"
    local faction      = (squad and squad.player_id) or "?"
    local smart        = squad and xsquad.get_squad_smart(squad)
    local smart_name   = smart and xlevel.get_smart_display_name(smart) or "?"
    local level_id     = xlevel.get_level_id(npc_se)
    local level_name   = level_id and xlevel.get_level_name(level_id) or "?"
    return creature, faction, smart_name, level_name
end

-- Pattern mirrors xr_effects.kill_squad (STALKER-Anomaly-gamedata
-- scripts/xr_effects.script:3472-3478). Online: game_object:kill fires
-- npc_on_death -> squad:on_npc_death -> SendScriptCallback("squad_on_npc_death").
-- Offline: server_entity:kill fires the equivalent server-side path. Both end
-- at the same callback ab_smart_balance listens to.
local function _kill_one(npc_id)
    local cl_obj = db.storage[npc_id] and db.storage[npc_id].object
    if cl_obj then
        cl_obj:kill(cl_obj)
        return "online"
    end
    local se = alife_object(npc_id)
    if se then
        se:kill()
        return "offline"
    end
    return nil
end

-- Strict alternation: even ticks pick on-level, odd ticks pick off-level.
-- Falls back to the other pool if the chosen pool is empty (e.g. early in the
-- run when off-level squads haven't been spawned by alife yet).
local function _pick_pool(on_level, off_level)
    if _tick_count % 2 == 0 then
        if #on_level > 0 then return on_level, "on" end
        return off_level, "off"
    end
    if #off_level > 0 then return off_level, "off" end
    return on_level, "on"
end

local function _tick()
    ResetTimeEvent(TIMER_EV, TIMER_TICK, KILL_INTERVAL)
    if not _running then return end
    if not db or not db.actor then return end
    _tick_count = _tick_count + 1
    local sim = alife()
    local actor_se = sim and sim:actor()
    local actor_level_id = actor_se and xlevel.get_level_id(actor_se)
    if not actor_level_id then
        _skips = _skips + 1
        log.info("[TEST] skip no_level")
        return
    end
    local on_level, off_level = _collect_candidates_split(actor_level_id)
    local pool, loc = _pick_pool(on_level, off_level)
    if #pool == 0 then
        _skips = _skips + 1
        log.info("[TEST] skip pool_empty on=%d off=%d", #on_level, #off_level)
        return
    end
    local victim_id = pool[math_random(#pool)]
    local creature, faction, smart_name, level_name = _kill_details(victim_id)
    local mode = _kill_one(victim_id)
    if mode then
        _kills = _kills + 1
        log.info(
            "[TEST] kill #%d npc_id=%d creature=%s faction=%s smart=%s level=%s mode=%s loc=%s on=%d off=%d",
            _kills, victim_id, creature, faction, smart_name, level_name,
            mode, loc, #on_level, #off_level)
        if db.actor and creature then
            news_manager.send_tip(db.actor,
                string_format("Killed %s (%s) at %s on %s",
                    creature, faction, smart_name, level_name),
                nil, nil, 3500)
        end
    else
        _skips = _skips + 1
        log.info("[TEST] skip kill_failed npc_id=%d loc=%s", victim_id, loc)
    end
end

--- @export console
function start()
    if _running then return end
    -- Authorize gate: refuses unless the actor has the AUTHORIZE_INFO info portion.
    -- Two-step unlock (give info portion, then start) prevents accidental console runs
    -- from killing real NPCs across the actor's whole world.
    if not db or not db.actor then
        log.info("[TEST] refused: no actor")
        return
    end
    if not db.actor:has_info(AUTHORIZE_INFO) then
        log.info("[TEST] refused: actor lacks info '%s'. Run: run_string db.actor:give_info_portion(\"%s\")",
            AUTHORIZE_INFO, AUTHORIZE_INFO)
        news_manager.send_tip(db.actor,
            "AlifeBalance test: REFUSED. First run: db.actor:give_info_portion(\"" .. AUTHORIZE_INFO .. "\")",
            nil, nil, 6000)
        return
    end
    _running = true
    _kills, _skips, _tick_count = 0, 0, 0
    RemoveTimeEvent(TIMER_EV, TIMER_TICK)
    CreateTimeEvent(TIMER_EV, TIMER_TICK, KILL_INTERVAL, _tick)
    log.info("[TEST] kill loop started (interval=%ds, 1:1 on-level / off-level alternation)", KILL_INTERVAL)
    news_manager.send_tip(db.actor,
        "AlifeBalance test: kill loop ON (" .. KILL_INTERVAL .. "s, 1:1 on/off-level)",
        nil, nil, 4000)
end

--- @export console
function stop()
    if not _running then return end
    _running = false
    RemoveTimeEvent(TIMER_EV, TIMER_TICK)
    log.info("[TEST] kill loop stopped (kills=%d skips=%d)", _kills, _skips)
    if db and db.actor then
        news_manager.send_tip(db.actor,
            "AlifeBalance test: kill loop OFF (kills=" .. _kills
            .. ", skips=" .. _skips .. ")",
            nil, nil, 4000)
    end
end

--- @export console
function toggle()
    if _running then stop() else start() end
end

-- ==================== FLOW TESTS ====================

-- session-cached logger for flow tests; one file per game session, appears immediately on disk
local _flow_log
local function _get_flow_log()
    if _flow_log then return _flow_log end
    local ts = os.date("%Y-%m-%d_%H-%M-%S")
    _flow_log = xlog.get_logger("TEST", { outfile = string_format("test_%s_%s.log", MOD, ts) })
    return _flow_log
end

-- xlog facade methods are plain functions (not OO methods). Call with `.`, not `:`.
local function _log_info(msg, ...)
    _get_flow_log().info(msg, ...)
    xlog.flush_all()
end

local function _tip(msg, ms)
    if db and db.actor then news_manager.send_tip(db.actor, msg, nil, nil, ms or 25000) end
end

-- Pick the nearest online stalker that passes xcreature.is_unscriptable.
local function _pick_npc()
    local actor = db.actor
    if not actor then return nil end
    local actor_pos = actor:position()
    local actor_id = actor:id()
    local best, best_dist = nil, math_huge
    for obj in xcreature.online_iter() do
        if obj:id() ~= actor_id and IsStalker(obj) and obj:alive()
            and not xcreature.is_unscriptable(obj) then
            local dist = obj:position():distance_to_sqr(actor_pos)
            if dist < best_dist then best, best_dist = obj, dist end
        end
    end
    return best
end

-- alife_create_item returns:
--   single cse userdata for non-ammo
--   array of cse for ammo when t.ammo exceeds box_size (engine splits)
local function _extract_ids(se)
    if not se then return {} end
    local se_type = type(se)
    if se_type == "userdata" then
        local id = (type(se.id) == "function" and se:id()) or se.id
        return id and { id } or {}
    end
    if se_type == "table" then
        if se.id then return { se.id } end
        local ids = {}
        for i = 1, #se do
            local cse = se[i]
            local id = cse and ((type(cse.id) == "function" and cse:id()) or cse.id)
            if id then ids[#ids + 1] = id end
        end
        return ids
    end
    return {}
end

local function _inject(npc, sec, count, ammo)
    local all_ids = {}
    for i = 1, count do
        local se = xinventory.create_item(sec, npc:id(), ammo and { ammo = ammo } or nil)
        local ids = _extract_ids(se)
        if #ids == 0 then
            _log_info("[INJECT WARN] %s #%d create returned type=%s (no ids)", sec, i, type(se))
        end
        for _, id in ipairs(ids) do all_ids[#all_ids + 1] = id end
    end
    return all_ids
end

local function _cleanup(ids)
    local released = 0
    for _, id in ipairs(ids or {}) do
        if alife_object(id) then alife_release_id(id); released = released + 1 end
    end
    return released
end

local function _find_mismatched_ammo(opts)
    local candidates = {
        "ammo_9x18_fmj", "ammo_pkm_100", "ammo_gauss",
        "ammo_5.45x39_fmj", "ammo_12x76_dart", "ammo_5.7x28_ss190",
        "ammo_9x39_pab9", "ammo_7.62x54_7h1",
    }
    for _, sec in ipairs(candidates) do
        if ini_sys:section_exist(sec)
            and xinventory.resolve_ammo_category(sec, opts) == "ammo_not_equipped" then
            return sec
        end
    end
    return nil
end

--- Inventory sanitization: ab_inventory_balance.trim_npc end-to-end.
--- Inject 20 medkits + 1 stack of mismatched ammo (200 rounds) into the
--- nearest test-eligible NPC, run trim_npc, assert the per-category release
--- counts match the ceilings in ab_inventory_policy.ltx.
--- @export console
function ab_test_inventory_sanitization()
    local TEST = "inventory_sanitization"
    _log_info("[BEGIN] %s", TEST)

    local npc = _pick_npc()
    if not npc then
        _log_info("[FAIL] %s: no eligible NPC near actor", TEST)
        _tip("[FAIL] " .. TEST .. ": no eligible NPC")
        return
    end
    local npc_id = npc:id()
    local npc_name = npc:name() or "?"
    _log_info("[SETUP] npc=%d name=%s", npc_id, npc_name)

    local opts = xinventory.get_category_opts(npc)
    local before = xinventory.classify(npc, opts)
    _log_info("[SNAPSHOT before] medkit=%d ammo_not_equipped=%d",
        before.medkit or 0, before.ammo_not_equipped or 0)

    local mismatched = _find_mismatched_ammo(opts)
    if not mismatched then
        _log_info("[FAIL] %s: no mismatched ammo section found", TEST)
        _tip("[FAIL] " .. TEST .. ": no mismatched ammo section")
        return
    end

    local INJECT_MEDKIT = 20
    local INJECT_AMMO = 200
    local medkit_ids = _inject(npc, "medkit", INJECT_MEDKIT)
    local ammo_ids = _inject(npc, mismatched, 1, INJECT_AMMO)
    _log_info("[INJECT] medkit ids=%d (requested %d), %s ids=%d (requested 1 stack of %d rounds)",
        #medkit_ids, INJECT_MEDKIT, mismatched, #ammo_ids, INJECT_AMMO)

    -- alife->CInventory sync takes one frame. Defer the assertion by 1 second.
    CreateTimeEvent(0, "ab_test_inv_sanit_phase2", 1, function()
        local npc2 = level.object_by_id(npc_id)
        if not npc2 then
            _log_info("[FAIL] %s: npc went offline before phase 2", TEST)
            _tip("[FAIL] " .. TEST .. ": npc offline")
            _cleanup(medkit_ids); _cleanup(ammo_ids)
            return true
        end

        local opts2 = xinventory.get_category_opts(npc2)
        local mid = xinventory.classify(npc2, opts2)
        local mid_medkit = mid.medkit or 0
        local mid_ammo = mid.ammo_not_equipped or 0
        _log_info("[SNAPSHOT mid] medkit=%d ammo_not_equipped=%d", mid_medkit, mid_ammo)

        local result = ab_inventory_balance.trim_npc(npc2)
        _log_info("[ACTION] trim_npc released=%d dt=%.2fms", result.released, result.dt_ms)
        for cat, count in pairs(result.released_by_category) do
            _log_info("[ACTION]   released %s = %d", cat, count)
        end

        local policy = xinventory.load_policy("alifebalance\\ab_inventory_policy.ltx", { "ab_inventory_policy" })
        local MEDKIT_MAX = policy.ab_inventory_policy.rules.medkit.max
        local expected_medkit_released = math_max(mid_medkit - MEDKIT_MAX, 0)
        local actual_medkit_released = (result.released_by_category.medkit) or 0
        local actual_ammo_released = (result.released_by_category.ammo_not_equipped) or 0
        local expected_medkit_after = math_min(mid_medkit, MEDKIT_MAX)

        local ok_medkit = (actual_medkit_released == expected_medkit_released)
        local ok_ammo = (actual_ammo_released >= 1) and (mid_ammo > 0)

        local summary = string_format(
            "npc=%d %s | medkit %d->%d (released %d, cap %d) | ammo_neq %d (released %d stacks) | dt=%.2fms",
            npc_id, npc_name,
            mid_medkit, expected_medkit_after, actual_medkit_released, MEDKIT_MAX,
            mid_ammo, actual_ammo_released, result.dt_ms)

        _log_info("[SUMMARY] %s", summary)

        if ok_medkit and ok_ammo then
            _log_info("[PASS] %s | %s", TEST, summary)
            _tip(string_format("[PASS] %s\n%s", TEST, summary), 30000)
        else
            local reason = string_format(
                "medkit released=%d expected=%d ok=%s | ammo released=%d expected>=1 (mid=%d) ok=%s",
                actual_medkit_released, expected_medkit_released, tostring(ok_medkit),
                actual_ammo_released, mid_ammo, tostring(ok_ammo))
            _log_info("[FAIL] %s | %s | %s", TEST, summary, reason)
            _tip(string_format("[FAIL] %s\n%s\n%s", TEST, summary, reason), 30000)
        end

        local m_cleaned = _cleanup(medkit_ids)
        local a_cleaned = _cleanup(ammo_ids)
        _log_info("[TEARDOWN] released %d/%d medkit ids, %d/%d ammo ids (others already gone via trim)",
            m_cleaned, #medkit_ids, a_cleaned, #ammo_ids)
        return true
    end)
end
