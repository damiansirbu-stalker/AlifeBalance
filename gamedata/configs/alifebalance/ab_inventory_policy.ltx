; AlifeBalance inventory policy. Per-category ceilings for the inventory balance scanner
; (ab_inventory_balance.script). Cull releases items above max in each category. Single-value
; rows: "<category> = <max>". DLTX-overridable. Shape parsed by xinventory.load_policy.
;
; Ammo categories count in ROUNDS; other categories count in items. Sentinel categories
; (untouchable, equipped) are pre-filtered by xinventory and never reach this policy.
; Item-level runtime protections (story_id, companion-gifted, player-strapped) also gate
; via xinventory.get_category — never reach the cull pass.

[ab_inventory_policy]
medkit            = 5
bandage           = 5
antirad           = 3
stim              = 3
pill              = 3
food              = 5
drink             = 3
grenade           = 3
grenade_ammo      = 6
ammo_slot_2_t1    = 48     ; pistol basic, 3 mags
ammo_slot_2_t2    = 48     ; pistol AP
ammo_slot_3_t1    = 120    ; rifle basic, 4 mags
ammo_slot_3_t2    = 120    ; rifle AP
ammo_not_equipped = 0
weapon            = 1
outfit            = 1
helmet            = 1
artefact          = 3
device            = 1
crafting          = 3
other             = 3

; "money" intentionally absent: cull's on_surplus is release_item, which would destroy
; money pile items (kind=i_money pickups). Rare in NPC inventory but safer to leave a
; no-rule = keep gap than risk destruction.
