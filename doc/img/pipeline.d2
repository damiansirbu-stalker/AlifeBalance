direction: down

death: "NPC death\n(engine callback)" {
  style.fill: "#fee2e2"
  style.stroke: "#991b1b"
}

counter: "_deaths[level][faction] += 1" {
  shape: cylinder
  style.fill: "#dbeafe"
  style.stroke: "#1e40af"
}

tick: "60s scanner\n_periodic_tick" {
  style.fill: "#dbeafe"
  style.stroke: "#1e40af"
}

gate: "count >= threshold AND\neligible smart has open budget?" {
  shape: diamond
  style.fill: "#e0e7ff"
  style.stroke: "#3730a3"
}

advance: "advance last_respawn_update\n(farthest smart first)" {
  style.fill: "#bfdbfe"
  style.stroke: "#1e40af"
  style.bold: true
}

engine: "engine try_respawn\nnext alife tick" {
  style.fill: "#fee2e2"
  style.stroke: "#991b1b"
}

spawn: "SIMBOARD:create_squad" {
  style.fill: "#fca5a5"
  style.stroke: "#991b1b"
  style.bold: true
}

death -> counter
counter -> tick
tick -> gate
gate -> advance: yes
advance -> engine
engine -> spawn
