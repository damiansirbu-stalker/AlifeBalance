direction: down

ab: AlifeBalance {
  style.fill: "#dbeafe"
  style.stroke: "#1e40af"
  style.bold: true
}

zcp: ZCP {
  style.fill: "#fef3c7"
  style.stroke: "#854d0e"
}

field: "smart.last_respawn_update" {
  shape: cylinder
  style.fill: "#e5e7eb"
  style.stroke: "#374151"
}

engine: "X-Ray engine\ntry_respawn -> SIMBOARD:create_squad" {
  style.fill: "#fee2e2"
  style.stroke: "#991b1b"
}

ab -> field: writes
zcp -> field: reads + writes
field -> engine: reads
